{
  "expo": {
    "name": "Outfit Club",
    "slug": "vesta-native",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vesta",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alangael.vesta",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Outfit Club necesita acceso a las fotos que elijas para crear tu armario privado."
      }
    },
    "android": {
      "package": "com.alangael.vesta",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-secure-store",
      "react-native-iap",
      [
        "expo-image-picker",
        {
          "photosPermission": "Outfit Club accede únicamente a las fotos que elijas para crear tu armario privado.",
          "microphonePermission": false
        }
      ]
    ]
  }
}
